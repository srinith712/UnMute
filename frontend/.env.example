# Copy this file to .env.development (local) or .env.production (production)
# and fill in your actual values.

# REST API base URL (no trailing slash)
# Example: http://localhost:8080  |  https://api.yourdomain.com
REACT_APP_API_URL=

# WebSocket base URL
# Example: ws://localhost:8080/ws  |  wss://api.yourdomain.com/ws
REACT_APP_WS_URL=
